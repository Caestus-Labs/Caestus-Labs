# Caestus Labs Contact Form Configuration
# Copy this file to .env and fill in your actual values
# NEVER commit the .env file to version control

# Supabase Configuration
# Get these from your Supabase dashboard: Settings > API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Alternative API Configuration (if using different service)
API_PUBLISHABLE_KEY=your_publishable_key_here
API_SECRET_KEY=your_secret_key_here

# Security Settings
RATE_LIMIT_MAX_ATTEMPTS=3
RATE_LIMIT_TIME_WINDOW=300000
RATE_LIMIT_BLOCK_DURATION=900000

# Environment
NODE_ENV=production

# Contact Form Settings
MAX_MESSAGE_LENGTH=1000
MAX_NAME_LENGTH=100
MAX_COMPANY_LENGTH=100

# Feature Flags
ENABLE_FINGERPRINTING=true
ENABLE_SQL_INJECTION_CHECK=true
ENABLE_RATE_LIMITING=true
LOG_SECURITY_EVENTS=true